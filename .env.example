# Saleor GraphQL API endpoint
# Example: https://your-store.saleor.cloud/graphql/
SALEOR_API_URL=

# --- Authentication (choose one) ---

# Option A (preferred): Long-lived app token from Saleor Dashboard → Apps → Tokens
SALEOR_APP_TOKEN=

# Option B: Staff user credentials (tokenCreate mutation will be called on startup)
SALEOR_EMAIL=
SALEOR_PASSWORD=

# --- Shipping Portugal seed (seed:shipping-portugal) ---

# Channel slug to assign shipping methods to
SHIPPING_CHANNEL_SLUG=
# Warehouse slug to assign shipping zones to
SHIPPING_WAREHOUSE_SLUG=
